# 报告AI解读系统 - 环境变量模板（复制为 .env 后按实际环境修改）
# Docker Compose 使用项目根目录 .env；本地运行后端可使用 backend/.env

# ========== 必填（上线给用户使用） ==========
# 推理服务地址（安诊儿；本次实施为 sglang 部署，OpenAI 兼容接口）
VLLM_BASE_URL=http://localhost:8000
# 医院名称（界面展示）
HOSPITAL_NAME=报告AI解读

# ========== 数据库（生产必须 PostgreSQL） ==========
# Docker Compose 默认使用下方 postgres 服务，无需改 DATABASE_URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/report_ai
# 集群内 PostgreSQL 密码（Compose 用）
POSTGRES_PASSWORD=postgres

# ========== 推理服务可选参数 ==========
VLLM_MODEL_NAME=AntAngelMed
VLLM_TIMEOUT=30
VLLM_MAX_TOKENS=2048
VLLM_TEMPERATURE=0.3

# ========== OCR（上传报告图片解读时必填） ==========
OCR_SERVICE_URL=http://localhost:8866

# ========== LIS 对接（从本院 LIS 拉取报告时填写） ==========
LIS_ADAPTER=mock
LIS_USE_ASMX=false
LIS_API_BASE_URL=
# LIS_API_KEY=  # 若 LIS 需鉴权再填写

# ========== 嵌入/患者接口 ==========
EMBED_REPORT_MODE=list_select

# ========== 全站中文时区 ==========
TIMEZONE=Asia/Shanghai

# ========== 前端帮助与反馈链接（可选） ==========
# HELP_URL=
# FEEDBACK_URL=

# ========== 轻量知识增强（规范与指南注入） ==========
KNOWLEDGE_ENABLED=false
KNOWLEDGE_DIR=knowledge
KNOWLEDGE_MAX_CHARS=4000

# ========== SQL Server：病历号/门诊卡号 → HID 解析（与 LIS 配合使用） ==========
MSSQL_ENABLED=false
MSSQL_SERVER=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=
MSSQL_VIEW_HID=VW_BRJZXXK
MSSQL_COLUMN_PAT_NUM=pat_num
MSSQL_COLUMN_XH=xh

# ========== HL7（按需启用） ==========
# HL7_ENABLED=false
# HL7_PORT=2575
